{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AlertPatchRequest",
  "type": "object",
  "properties": {
    "estado": {
      "type": "string",
      "enum": ["NOVO", "VISTO", "EM SEGUIMENTO", "FECHADO"]
    },
    "prioridade": {
      "type": "string",
      "enum": ["BAIXA", "MEDIA", "ALTA"]
    }
  },
  "additionalProperties": false,
  "anyOf": [
    { "required": ["estado"] },
    { "required": ["prioridade"] }
  ]
}
